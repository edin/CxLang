module std.core;

public type i8 = char;
public type i16 = short;
public type i32 = int;
public type i64 = long long;

public type u8 = unsigned char;
public type u16 = unsigned short;
public type u32 = unsigned int;
public type u64 = unsigned long long;

public type usize = unsigned long long;
public type bool = int;
